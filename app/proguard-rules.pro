# =========================================================================
# Speculonic - ProGuard/R8 混淆与保留规则
# 所有注释均采用简体中文，符合项目规范
# =========================================================================

# -------------------------------------------------------------------------
# 1. 基础全局配置与元数据保留
# -------------------------------------------------------------------------
# 保留注解信息、泛型签名、内部类和封闭方法，这对于反射、依赖注入与序列化至关重要
-keepattributes *Annotation*,Signature,InnerClasses,EnclosingMethod,SourceFile,LineNumberTable

# -------------------------------------------------------------------------
# 2. kotlinx.serialization 官方防混淆规则
# -------------------------------------------------------------------------
# 保留 Serializable 注解修饰的类及其自动生成的辅助类和序列化器
-keepclassmembers class * {
    @kotlinx.serialization.Serializable *;
}
-keep class *$$serializer { *; }
-keepclassmembers class * {
    *** Companion;
}
-keepclassmembers class * {
    *** $serializer;
}

# -------------------------------------------------------------------------
# 3. 业务数据模型与网络实体 (DTO) 保留
# -------------------------------------------------------------------------
# 核心 Subsonic 协议的数据传输对象 (DTO) 绝对不能混淆其字段名，
# 否则 kotlinx.serialization 在反序列化 JSON 时会因为字段名不匹配而崩溃。
-keep class de.lwp2070809.speculonic.network.model.** { *; }

# -------------------------------------------------------------------------
# 4. 第三方库：jaudiotagger
# -------------------------------------------------------------------------
# UI层（SongDetailDialog）中使用了 tag.javaClass.simpleName 来获取容器版本信息，
# 且底层大量使用反射实例化 Tag 读写器，因此必须保留其所有类结构不被混淆，
# 并屏蔽由于缺失可选依赖引起的 R8 警告。
-keep class org.jaudiotagger.** { *; }
-dontwarn org.jaudiotagger.**
